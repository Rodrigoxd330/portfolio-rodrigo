---
import Layout from "../Layouts/Layout.astro";
import { BotonCopiar, NotificacionesToast } from '../Components/BotonCopiar.jsx';
import { GaleriaProyectos } from '../Components/GaleriaProyectos.jsx';
import proyectosData from '../Data/proyectos.json'; // Astro permite importar JSON directo
import type { Proyecto } from '../Types/Proyecto';
const proyectos: Proyecto[] = proyectosData;

const email = "rodrigo.bchr@gmail.com"
const cvLink = "https://drive.google.com/file/d/1m0UPnHm4FK5a-8QYmrKOE9IX5jvNlqKj/view";
const linkedinLink = "https://www.linkedin.com/in/rodrigo-chang-168330319/";
const githubLink = "https://github.com/Rodrigoxd330";

const btnClasses = "group flex items-center gap-3 px-4 py-2 bg-google-gray rounded-full hover:bg-white hover:shadow-card transition-all cursor-pointer border border-transparent hover:border-gray-100 copy-btn";
---

<Layout>
    <NotificacionesToast client:load />

    <main class="flex flex-row justify-center gap-48 items-center">
        <div>
            <img src="/foto-rodrigo.jpg" alt="Foto de Rodrigo" class="w-96 h-96 rounded-full shrink-0 object-cover shadow-2xl" />
        </div>  
        <section class="flex flex-col justify-center items-center gap-4">
            
            <header class ="flex flex-col justify-items-start items-center">
                <h1 class="font-heading text-4xl md:text-5xl font-bold text-text-primary mb-2">Rodrigo Chang</h1>       
                <div class="flex flex-col md:flex-row gap-4 mt-2 justify-center md:justify-start">                                  
                    <BotonCopiar client:visible textoACopiar={email} className={btnClasses} title="Copiar email">
                        <svg class="w-5 h-5 text-text-body group-hover:text-google-blue transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                        </svg>                  
                        <span class="font-sans text-text-body text-sm font-medium">{email}</span>                   
                        <svg class="w-4 h-4 text-gray-400 opacity-0 group-hover:opacity-100 icon-copy transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                        </svg>
                    </BotonCopiar>                                          
                </div>
            </header>

            <article class="max-w-3xl text-center md:text-left">
                <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Pellentesque eleifend ex eget tempor interdum. Praesent congue cursus lorem vitae tristique. Vivamus metus sapien, mollis sit amet lorem fringilla, iaculis fermentum nulla. Vestibulum convallis nisl vel pellentesque lobortis. Cras sollicitudin sit amet eros non ullamcorper. Fusce tincidunt mauris sit amet pharetra varius. Nunc hendrerit dolor non hendrerit egestas. Morbi velit purus, rhoncus sed hendrerit vitae, consequat id lectus. Etiam vehicula purus ex, in posuere sapien blandit at. Vestibulum vitae velit pharetra, convallis dui in, tempus enim. Nunc fringilla facilisis ullamcorper. Nam at quam quis diam gravida sollicitudin. Ut at turpis feugiat, tristique turpis non, aliquet nulla. Donec consequat nec neque at euismod. Cras non elit quis erat imperdiet bibendum. Duis in ultricies diam.</p>  
            </article>
            
            <div class="mt-6 flex flex-col md:flex-row items-center gap-6">
                
                <a 
                    href={cvLink}
                    target="_blank"
                    rel="noopener noreferrer nofollow"
                    class="px-6 py-3 bg-google-blue text-white font-medium rounded-full hover:bg-blue-600 shadow-lg hover:shadow-xl transition-all inline-flex items-center gap-2 transform hover:-translate-y-0.5"
                >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                    </svg>
                    Descargar CV
                </a>

                <div class="h-8 w-px bg-gray-200 hidden md:block"></div>

                <div class="flex gap-4">
                    <a href={githubLink} target="_blank" rel="noopener noreferrer" class="p-2 text-gray-500 hover:text-black transition-colors hover:bg-gray-100 rounded-full" aria-label="GitHub">
                        <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
                        </svg>
                    </a>

                    <a href={linkedinLink} target="_blank" rel="noopener noreferrer" class="p-2 text-gray-500 hover:text-[#0077b5] transition-colors hover:bg-blue-50 rounded-full" aria-label="LinkedIn">
                        <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd"></path>
                        </svg>
                    </a>
                </div>
            </div>

        </section>      
    </main>
	<section>
		<GaleriaProyectos client:visible listaProyectos={proyectos}/>
	</section>

</Layout>