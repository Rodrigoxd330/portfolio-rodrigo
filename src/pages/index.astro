---
import Layout from "../Layouts/Layout.astro";
import { BotonCopiar } from '../Components/BotonCopiar.jsx';
import { GaleriaProyectos } from '../Components/GaleriaProyectos.jsx';
import proyectosData from '../Data/proyectos.json'; 

const proyectos = proyectosData;
const email = "rodrigo.bchr@gmail.com";
const linkedinLink = "https://www.linkedin.com/in/rodrigo-chang-168330319/";
const githubLink = "https://github.com/Rodrigoxd330";

const btnClasses = "group flex items-center gap-3 px-4 py-2 bg-gray-50 rounded-full hover:bg-white hover:shadow-card transition-all cursor-pointer border border-zinc-300/80 hover:border-gray-100 copy-btn";
---
<Layout>    
    <main class="flex flex-col md:flex-row justify-center gap-8 md:gap-20 lg:gap-28 items-center py-8 md:py-12 md:px-20 px-6">
        <div class="shrink-0">
            <img 
                src="/foto-rodrigo.jpg" 
                alt="Foto de Rodrigo Chang" 
                class="w-48 h-48 md:w-72 md:h-72 lg:w-80 lg:h-80 rounded-full object-cover shadow-xl aspect-square" 
            />
        </div>
        <section class="flex flex-col justify-center items-center md:items-start gap-4 text-center md:text-left max-w-xl">        
            <header class="flex flex-col items-center md:items-start w-full">
                <h1 class="font-heading text-4xl md:text-5xl font-bold text-text-primary mb-6">Rodrigo Chang</h1>
                <h2 class="text-lg text-gray-600 font-light mb-4">Ingeniero Informático | Web Developer & AI Engineer</h2>      
                                
                <div class="flex flex-col sm:flex-row gap-3 justify-center md:justify-start items-center w-full">                    
                    <BotonCopiar client:visible textoACopiar={email} title="Copiar email"
                        className={btnClasses}
                    >
                        <svg class="w-5 h-5 text-text-body group-hover:text-google-blue transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                        </svg>                  
                        <span class="font-sans text-text-body text-xs md:text-sm font-medium break-all">{email}</span>                   
                        <svg class="w-4 h-4 text-gray-400 opacity-0 group-hover:opacity-100 icon-copy transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                        </svg>
                    </BotonCopiar>        
                    
                    <div class="flex gap-3">
                        <a href={githubLink} target="_blank" rel="noopener noreferrer" class={btnClasses} aria-label="GitHub">
                            <svg class="w-5 h-5 text-gray-500 group-hover:text-black transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
                            </svg>
                            <span class="text-xs md:text-sm font-medium text-text-body">GitHub</span>
                        </a>
                        <a href={linkedinLink} target="_blank" rel="noopener noreferrer" class={btnClasses} aria-label="LinkedIn">
                            <svg class="w-5 h-5 text-gray-500 group-hover:text-[#0077b5] transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd"></path>
                            </svg>
                            <span class="text-xs md:text-sm font-medium text-text-body">LinkedIn</span>
                        </a>
                    </div>                                              
                </div>
            </header>
            
            <article class="text-text-body text-sm md:text-base leading-relaxed text-gray-700 text-justify">
                <p>
                    Estudiante de noveno ciclo de Ingeniería Informática en la PUCP enfocado en la 
                    automatización de procesos uniendo el desarrollo web moderno con la 
                    inteligencia Artificial. En cada proyecto, siempre busco identificar los 
                    dolores del usuario desde la raíz, asegurando que cada solución sea adecuada y efectiva.                    
                </p>  
            </article>
        </section>       
    </main>
    <section class="mt-12">
        <GaleriaProyectos client:visible listaProyectos={proyectos} />
    </section>
</Layout>